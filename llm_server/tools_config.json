{
  "tools": [
    {
      "name": "open_browser",
      "path": "browser_server/open_browser.py",
      "description": "打开指定的网页浏览器",
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "要打开的网页URL"
        }
      ],
      "examples": [
        "[TOOL:open_browser,https://www.example.com]",
        "[TOOL:open_browser,https://github.com]"
      ]
    },
    {
      "name": "click_mouse",
      "path": "keyboard_server/mousecontrol.py",
      "description": "鼠标点击操作，可指定坐标位置",
      "parameters": [
        {
          "name": "x",
          "type": "number",
          "description": "x坐标，如果为None则点击当前位置"
        },
        {
          "name": "y",
          "type": "number",
          "description": "y坐标，如果为None则点击当前位置"
        },
        {
          "name": "click_type",
          "type": "string",
          "description": "点击类型，可选值：'left', 'right', 'middle'，默认为'left'"
        },
        {
          "name": "clicks",
          "type": "number",
          "description": "点击次数，默认为1"
        },
        {
          "name": "interval",
          "type": "number",
          "description": "点击间隔时间，默认为0.0"
        }
      ],
      "examples": [
        "[TOOL:click_mouse,100,200,left,1,0.0]",
        "[TOOL:click_mouse,300,400,right,1,0.1]",
        "[TOOL:click_mouse,None,None,left,2,0.2]"
      ]
    },
    {
      "name": "get_position",
      "path": "keyboard_server/mousecontrol.py",
      "description": "获取当前鼠标位置的坐标",
      "parameters": [],
      "examples": [
        "[TOOL:get_position]"
      ]
    },
    {
      "name": "move_mouse",
      "path": "keyboard_server/mousecontrol.py",
      "description": "移动鼠标到指定位置",
      "parameters": [
        {
          "name": "x",
          "type": "number",
          "description": "目标x坐标"
        },
        {
          "name": "y",
          "type": "number",
          "description": "目标y坐标"
        },
        {
          "name": "duration",
          "type": "number",
          "description": "移动持续时间，控制移动速度，默认为0.0"
        }
      ],
      "examples": [
        "[TOOL:move_mouse,300,400,0.5]",
        "[TOOL:move_mouse,500,600,1.0]"
      ]
    },

    {
      "name": "find_text_coordinates",
      "path": "ocr/ocr.py",
      "description": "查找指定文字的中心点坐标",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "description": "要查找的文字内容"
        }
      ],
      "examples": [
        "[TOOL:find_text_coordinates,赞助模之屋]",
        "[TOOL:find_text_coordinates,开始游戏]"
      ]
    },
    {
  "name": "get_all_text",
  "path": "ocr/ocr.py",
  "description": "获取全屏所有识别到的文本",
  "parameters": [],
  "examples": [
    "[TOOL:get_all_text]"
  ]
}
  ]
}